# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────

# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — get from Stripe Dashboard > Webhooks > your endpoint > Signing secret
# For local dev: run `stripe listen --forward-to localhost:5000/api/ticket/webhook`
# and copy the whsec_... secret it prints
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Frontend URL (used for Stripe redirect URLs) ─────────────────────────────
# FRONTEND_URL=http://localhost:3000

# ── Email (optional, for notifications) ──────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
